# ============================================
# API & App Configuration
# ============================================
APP_NAME=agente-ia-ofm
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
API_PORT=8000
API_HOST=0.0.0.0

# ============================================
# Database - Supabase
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# LLM Configuration - OpenRouter
# ============================================
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=anthropic/claude-3-haiku
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ============================================
# Langfuse - Observability
# ============================================
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================
# Uazapi - WhatsApp API
# ============================================
UAZAPI_INSTANCE_ID=your-instance-id
UAZAPI_API_TOKEN=your-uazapi-token
UAZAPI_WEBHOOK_VERIFY_TOKEN=your-webhook-token
UAZAPI_WEBHOOK_URL=https://your-domain.com/webhooks/whatsapp

# ============================================
# PixBank - Payment Gateway
# ============================================
PIXBANK_API_KEY=your-pixbank-api-key
PIXBANK_SECRET_KEY=your-pixbank-secret-key
PIXBANK_WEBHOOK_SECRET=your-webhook-secret
PIXBANK_WEBHOOK_URL=https://your-domain.com/webhooks/pixbank

# ============================================
# Kestra - Workflow Orchestration
# ============================================
KESTRA_URL=http://localhost:8080
KESTRA_API_KEY=your-kestra-api-key

# ============================================
# Celery Configuration
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_TIME_LIMIT=300

# ============================================
# Security
# ============================================
SECRET_KEY=your-secret-key-change-this
WEBHOOK_SECRET_WHATSAPP=your-webhook-secret
WEBHOOK_SECRET_PIXBANK=your-webhook-secret

# ============================================
# Follow-up Configuration
# ============================================
FOLLOWUP_INITIAL_DELAY_MINUTES=20
FOLLOWUP_RETRY_HOURS=2
FOLLOWUP_MAX_ATTEMPTS=5
INACTIVE_DAYS_THRESHOLD=30

# ============================================
# RAG Configuration
# ============================================
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
